{
  "name": "@electron-hot-updater/core",
  "version": "0.1.0",
  "description": "Core SDK for Electron hot updates — bootstrap loader, updater client, fingerprint calculator",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "electron": ">=20.0.0",
    "electron-updater": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "electron": { "optional": true },
    "electron-updater": { "optional": true }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicepkg/electron-hot-updater",
    "directory": "packages/core"
  },
  "keywords": ["electron", "hot-update", "code-push", "incremental-update", "ota"]
}
