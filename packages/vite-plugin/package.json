{
  "name": "@electron-hot-updater/vite",
  "version": "0.1.0",
  "description": "Vite plugin for electron-hot-updater — auto-injects bootstrap.js into builds",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": { "optional": true }
  },
  "devDependencies": {
    "@electron/asar": "^1.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicepkg/electron-hot-updater",
    "directory": "packages/vite-plugin"
  },
  "keywords": ["electron", "hot-update", "vite", "electron-forge"]
}
